# Gmail IMAP credentials (dedicated job search inbox)
GMAIL_ADDRESS=your-job-alerts@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── OpenRouter ──────────────────────────────────────────────────────────────
# All LLM calls route through OpenRouter (https://openrouter.ai).
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Track B — Stage 1: Structured extraction from raw email text.
# A fast, cheap model. This runs on every email.
OPENROUTER_STAGE1_MODEL=openai/gpt-5.4-nano

# Track A + B — Stage 5: Match scoring against your candidate profile.
# Used for all scoring calls and as the default fallback model.
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Tailoring: resume edits, cover letters, interview prep.
# Runs only when you react ✏️ or the daily batch processor fires.
OPENROUTER_TAILOR_MODEL=anthropic/claude-sonnet-4.6

# Trend analysis: skill canonicalization for the !trend ChatOps command.
# Uses a lightweight model — only runs on-demand when you post !trend in Slack.
OPENROUTER_TREND_MODEL=openai/gpt-4o-mini

# ─── Stage 5 confidence threshold ────────────────────────────────────────────
# A NO verdict is ALWAYS rejected — confidence is irrelevant. A YES or MAYBE
# verdict is kept only when its confidence (0.0–1.0) is at or above this
# threshold; otherwise it is dropped before reaching Slack.
#   0.0   — keep every YES/MAYBE; only NO is rejected
#   0.5   — default
#   0.75  — strict; only surface YES/MAYBE the model is highly confident about
# The same value also gates AUTO_MATCH: a YES verdict with confidence >=
# max(CONFIDENCE_THRESHOLD, 0.8) is marked AUTO_MATCH in the digest.
CONFIDENCE_THRESHOLD=0.75

# ─── Pipeline behavior ───────────────────────────────────────────────────────
# Assets generated per Tailor run (✏️ reaction or batch processor).
# Options: resume, cover_letter, interview_prep  (comma-separated)
# On-demand alternatives via ChatOps: !coverletter, !prep, !polish
GENERATE_ASSETS=resume
# ON_DEMAND=polished_resume,cover_letter,interview_prep

# Autopilot — speculative execution after Stage 5 scoring.
# When enabled, listings with a YES/MAYBE verdict at or above CONFIDENCE_THRESHOLD
# are queued for an asynchronous Speculative Agent that runs deep research and a
# Claude match-analysis pass up front (no expensive resume edits). Results are
# posted to Slack directly so the user can triage with full context. Any
# post-research NO verdict is auto-passed. Run after the pipeline with
# `python -m src.process_queue`, or use `./script.sh` to chain the full batch.
AUTOPILOT_ENABLED=false
# Max concurrent listings processed by the Speculative Agent.
AUTOPILOT_CONCURRENCY=3

# ─── Slack notifications ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=C0123456789

# ─── Rotating residential proxy (optional, recommended for heavy scraping) ──
# Apply Daemon can route Track A (jobspy) and Track C (deep-research scrapes)
# through an IPRoyal sticky residential session. Without a proxy, aggressive
# polling of LinkedIn / Indeed will get your home IP rate-limited or banned.
# Leave these blank to scrape direct from your local IP (fine for ~10–20
# requests / day on DuckDuckGo + a friendly Indeed query).
#
# IPRoyal "magic-string" sticky session — see src/proxy_manager.py for details.
# IPROYAL_USERNAME=your-iproyal-user
# IPROYAL_PASSWORD=your-iproyal-pass
# IPROYAL_HOST=geo.iproyal.com
# IPROYAL_PORT=12321
# IPROYAL_SESSION_TTL_MINUTES=30
# IPROYAL_SCHEME=http   # one of: http, https, socks5, socks5h
